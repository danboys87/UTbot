# ── Bitget API ────────────────────────────────────────────────────────────────
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# ── Mode ──────────────────────────────────────────────────────────────────────
# true  = simulasi saja (tidak ada transaksi nyata)
# false = live trading
DRY_RUN=true

# ── Telegram Notifikasi ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── AI Analyst (Claude API) ───────────────────────────────────────────────────
# Daftar di https://console.anthropic.com → API Keys
# Diperlukan untuk fitur AI Analyst otomatis + /analyze command
ANTHROPIC_API_KEY=

# ── JSONBin (cloud state persistence) ────────────────────────────────────────
JSONBIN_API_KEY=
JSONBIN_BIN_ID=

# ── Log Level ─────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
